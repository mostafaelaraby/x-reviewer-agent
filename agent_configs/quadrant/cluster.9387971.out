eaming and Robust Refusal},\n307\tauthor={Mantas Mazeika and Long Phan and Xuwang Yin and Andy Zou and Zifan Wang and Norman Mu and Elham Sakhaee and Nathaniel Li and Steven Basart and Bo Li and David Forsyth and Dan Hendrycks},\n308\tyear={2024},\n309\teprint={2402.04249},\n310\tarchivePrefix={arXiv},\n311\tprimaryClass={cs.LG},\n312\tjournal={arXiv preprint arXiv:2402.04249}\n313\t}\n314\t\n315\t@article{maloyan2024trojan,\n316\t  title={Trojan detection in large language models: Insights from the trojan detection challenge},\n317\t  author={Maloyan, Narek and Verma, Ekansh and Nutfullin, Bulat and Ashinov, Bislan},\n318\t  journal={arXiv preprint arXiv:2404.13660},\n319\t  year={2024}\n320\t}\n321\t\n322\t@misc{xhonneux2025generativeapproachllmharmfulness,\n323\t      title={A generative approach to LLM harmfulness detection with special red flag tokens}, \n324\t      author={Sophie Xhonneux and David Dobre and Mehrnaz Mofakhami and Leo Schwinn and Gauthier Gidel},\n325\t      year={2025},\n326\t      eprint={2502.16366},\n327\t      archivePrefix={arXiv},\n328\t      primaryClass={cs.CL},\n329\t      url={https://arxiv.org/abs/2502.16366}, \n330\t}\n331\t\n332\t@misc{jain2024refusaltokenssimpleway,\n333\t      title={Refusal Tokens: A Simple Way to Calibrate Refusals in Large Language Models}, \n334\t      author={Neel Jain and Aditya Shrivastava and Chenyang Zhu and Daben Liu and Alfy Samuel and Ashwinee Panda and Anoop Kumar and Micah Goldblum and Tom Goldstein},\n335\t      year={2024},\n336\t      eprint={2412.06748},\n337\t      archivePrefix={arXiv},\n338\t      primaryClass={cs.LG},\n339\t      url={https://arxiv.org/abs/2412.06748}, \n340\t}\n341\t\n342\t\n343\t@article{dolma,\n344\t  title = {{Dolma: an Open Corpus of Three Trillion Tokens for Language Model Pretraining Research}},\n345\t  author={\n346\t    Luca Soldaini and Rodney Kinney and Akshita Bhagia and Dustin Schwenk and David Atkinson and\n347\t    Russell Authur and Ben Bogin and Khyathi Chandu and Jennifer Dumas and Yanai Elazar and\n348\t    Valentin Hofmann and Ananya Harsh Jha and Sachin Kumar and Li Lucy and Xinxi Lyu and\n349\t    Nathan Lambert and Ian Magnusson and Jacob Morrison and Niklas Muennighoff and Aakanksha Naik and\n350\t    Crystal Nam and Matthew E. Peters and Abhilasha Ravichander and Kyle Richardson and Zejiang Shen and\n351\t    Emma Strubell and Nishant Subramani and Oyvind Tafjord and Pete Walsh and Luke Zettlemoyer and\n352\t    Noah A. Smith and Hannaneh Hajishirzi and Iz Beltagy and Dirk Groeneveld and Jesse Dodge and Kyle Lo\n353\t  },\n354\t  year = {2024},\n355\t  journal={arXiv preprint},\n356\t}\n357\t\n358\t\n359\t\n360\t@inproceedings{maini-etal-2024-rephrasing,\n361\t    title = \"Rephrasing the Web: A Recipe for Compute and Data-Efficient Language Modeling\",\n362\t    author = \"Maini, Pratyush  and\n363\t      Seto, Skyler  and\n364\t      Bai, Richard  and\n365\t      Grangier, David  and\n366\t      Zhang, Yizhe  and\n367\t      Jaitly, Navdeep\",\n368\t    editor = \"Ku, Lun-Wei  and\n369\t      Martins, Andre  and\n370\t      Srikumar, Vivek\",\n371\t    booktitle = \"Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics (Volume 1: Long Papers)\",\n372\t    month = aug,\n373\t    year = \"2024\",\n374\t    address = \"Bangkok, Thailand\",\n375\t    publisher = \"Association for Computational Linguistics\",\n376\t    url = \"https://aclanthology.org/2024.acl-long.757/\",\n377\t    doi = \"10.18653/v1/2024.acl-long.757\",\n378\t    pages = \"14044--14072\",\n379\t    abstract = \"Large language models are trained on massive scrapes of the web, which are often unstructured, noisy, and poorly phrased. Current scaling laws show that learning from such data requires an abundance of both compute and data, which grows with the size of the model being trained. This is infeasible both because of the large compute costs and duration associated with pre-training, and the impending scarcity of high-quality data on the web. In this work, we propose Web Rephrase Augmented Pre-training (WRAP) that uses an off-the-shelf instruction-tuned model prompted to paraphrase documents on the web in specific styles such as {\\textquotedblleft}like Wikipedia{\\textquotedblright} or in {\\textquotedblleft}question-answer format{\\textquotedblright} to jointly pre-train LLMs on real and synthetic rephrases. First, we show that using WRAP on the C4 dataset, which is naturally noisy, speeds up pre-training by {\\textasciitilde}3x. At the same pre-training compute budget, it improves perplexity by more than 50{\\%} on average across different subsets of the Pile, and improves zero-shot question answer accuracy across 13 tasks by more than 2{\\%}. Second, we investigate the impact of the re-phrasing style on the performance of the model, offering insights into how the composition of the training data can impact the performance of LLMs in OOD settings. Our gains are attributed to the fact that re-phrased synthetic data has higher utility than just real data because it (i) incorporates style diversity that closely reflects downstream evaluation style, and (ii) has higher {\\textquoteleft}quality' than web-scraped data.\"\n380\t}\n381\t\n382\t\n383\t\n384\t\n385\t@misc{qi2024safetyalignmentjusttokens,\n386\t      title={Safety Alignment Should Be Made More Than Just a Few Tokens Deep}, \n387\t      author={Xiangyu Qi and Ashwinee Panda and Kaifeng Lyu and Xiao Ma and Subhrajit Roy and Ahmad Beirami and Prateek Mittal and Peter Henderson},\n388\t      year={2024},\n389\t      eprint={2406.05946},\n390\t      archivePrefix={arXiv},\n391\t      primaryClass={cs.CR},\n392\t      url={https://arxiv.org/abs/2406.05946}, \n393\t}\n394\t\n395\t@misc{he2024safedataidentifyingbenign,\n396\t      title={What is in Your Safe Data? Identifying Benign Data that Breaks Safety}, \n397\t      author={Luxi He and Mengzhou Xia and Peter Henderson},\n398\t      year={2024},\n399\t      eprint={2404.01099},\n400\t      archivePrefix={arXiv},\n401\t      primaryClass={cs.LG},\n402\t      url={https://arxiv.org/abs/2404.01099}, \n403\t}\n404\t\n405\t@misc{taori2023stanford,\n406\t  title={Stanford alpaca: An instruction-following llama model},\n407\t  author={Taori, Rohan and Gulrajani, Ishaan and Zhang, Tianyi and Dubois, Yann and Li, Xuechen and Guestrin, Carlos and Liang, Percy and Hashimoto, Tatsunori B},\n408\t  year={2023},\n409\t  publisher={Stanford, CA, USA}\n410\t}\n411\t\n412\t@article{xue2020mt5,\n413\t  title={mt5: A massively multilingual pre-trained text-to-text transformer},\n414\t  author={Xue, L},\n415\t  journal={arXiv preprint arXiv:2010.11934},\n416\t  year={2020}\n417\t}\n418\t\n419\t@article{raffel2020exploring,\n420\t  title={Exploring the limits of transfer learning with a unified text-to-text transformer},\n421\t  author={Raffel, Colin and Shazeer, Noam and Roberts, Adam and Lee, Katherine and Narang, Sharan and Matena, Michael and Zhou, Yanqi and Li, Wei and Liu, Peter J},\n422\t  journal={Journal of machine learning research},\n423\t  volume={21},\n424\t  number={140},\n425\t  pages={1--67},\n426\t  year={2020}\n427\t}\n428\t\n429\t@article{gunasekar2023textbooks,\n430\t  title={Textbooks are all you need},\n431\t  author={Gunasekar, Suriya and Zhang, Yi and Aneja, Jyoti and Mendes, Caio C{\\'e}sar Teodoro and Del Giorno, Allie and Gopi, Sivakanth and Javaheripi, Mojan and Kauffmann, Piero and de Rosa, Gustavo and Saarikivi, Olli and others},\n432\t  journal={arXiv preprint arXiv:2306.11644},\n433\t  year={2023}\n434\t}\n435\t\n436\t@article{robey2024jailbreaking,\n437\t  title={Jailbreaking llm-controlled robots},\n438\t  author={Robey, Alexander and Ravichandran, Zachary and Kumar, Vijay and Hassani, Hamed and Pappas, George J},\n439\t  journal={arXiv preprint arXiv:2410.13691},\n440\t  year={2024}\n441\t}\n442\t\n443\t@article{o2025deep,\n444\t  title={Deep Ignorance: Filtering Pretraining Data Builds Tamper-Resistant Safeguards into Open-Weight LLMs},\n445\t  author={O'Brien, Kyle and Casper, Stephen and Anthony, Quentin and Korbak, Tomek and Kirk, Robert and Davies, Xander and Mishra, Ishan and Irving, Geoffrey and Gal, Yarin and Biderman, Stella},\n446\t  journal={arXiv preprint arXiv:2508.06601},\n447\t  year={2025}\n448\t}\n449\t\n450\t@inproceedings{\n451\tli2025when,\n452\ttitle={When Bad Data Leads to Good Models},\n453\tauthor={Kenneth Li and Yida Chen and Fernanda Vi{\\'e}gas and Martin Wattenberg},\n454\tbooktitle={Forty-second International Conference on Machine Learning},\n455\tyear={2025},\n456\turl={https://openreview.net/forum?id=SsLGTZKXf1}\n457\t}\n458\t\n459\t@inproceedings{bengio2009curriculum,\n460\t  title={Curriculum learning},\n461\t  author={Bengio, Yoshua and Louradour, J{\\'e}r{\\^o}me and Collobert, Ronan and Weston, Jason},\n462\t  booktitle={Proceedings of the 26th annual international conference on machine learning},\n463\t  pages={41--48},\n464\t  year={2009}\n465\t}\n466\t\n467\t\n468\t@inproceedings{graves2017automated,\n469\t  title={Automated curriculum learning for neural networks},\n470\t  author={Graves, Alex and Bellemare, Marc G and Menick, Jacob and Munos, Remi and Kavukcuoglu, Koray},\n471\t  booktitle={international conference on machine learning},\n472\t  pages={1311--1320},\n473\t  year={2017},\n474\t  organization={Pmlr}\n475\t}\n476\t\n477\t@article{jiang2024adaptive,\n478\t  title={Adaptive data optimization: Dynamic sample selection with scaling laws},\n479\t  author={Jiang, Yiding and Zhou, Allan and Feng, Zhili and Malladi, Sadhika and Kolter, J Zico},\n480\t  journal={arXiv preprint arXiv:2410.11820},\n481\t  year={2024}\n482\t}\n483\t\n484\t@inproceedings{\n485\tye2025data,\n486\ttitle={Data Mixing Laws: Optimizing Data Mixtures by Predicting Language Modeling Performance},\n487\tauthor={Jiasheng Ye and Peiju Liu and Tianxiang Sun and Jun Zhan and Yunhua Zhou and Xipeng Qiu},\n488\tbooktitle={The Thirteenth International Conference on